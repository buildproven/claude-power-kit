# Social Media API Credentials
# Copy this to .env and fill in your actual values

# Twitter API (from developer.twitter.com)
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# LinkedIn API (from linkedin.com/developers)
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# Facebook Page (from developers.facebook.com)
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here
FACEBOOK_PAGE_ID=your_page_id_here

# AI Image Generation APIs (for LinkedIn Carousel Generator)
# ------------------------------------------------------------

# Google Gemini API (from ai.google.dev/gemini-api/docs)
# Cost: $0.05/image = $0.35 per 7-slide carousel (RECOMMENDED)
GOOGLE_GENAI_API_KEY=your_google_genai_key_here

# OpenAI API (from platform.openai.com/api-keys)
# Cost: $0.133/image = $0.93 per 7-slide carousel (FALLBACK)
OPENAI_API_KEY=your_openai_key_here

# Carousel Generator Settings
CAROUSEL_DEFAULT_MODEL=nano-banana-pro
CAROUSEL_OUTPUT_DIR=/path/to/your/output/carousels
CAROUSEL_ENABLE_FALLBACK=true

# Perplexity API (from perplexity.ai/account/api/group)
# Used for: deep research, market analysis, competitor intelligence
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Firecrawl API (from firecrawl.dev)
# Used for: competitor website scraping, bulk page analysis, pricing extraction
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# MCP Server Tokens (required for Claude Code MCP servers)
# ------------------------------------------------------------

# Linear (from linear.app/settings/api)
LINEAR_API_KEY=your_linear_api_key_here


# Glif API (from glif.app/settings/api-tokens)
GLIF_API_TOKEN=your_glif_api_token_here

# DataForSEO (from dataforseo.com)
DATAFORSEO_LOGIN=your_email_here
DATAFORSEO_PASSWORD=your_password_here

# LinkedIn extended (for MCP server)
LINKEDIN_PERSON_URN=urn:li:person:your_urn_here

# Twitter bearer (for read-only MCP)
TWITTER_BEARER_TOKEN=your_bearer_token_here
