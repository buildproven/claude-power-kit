# Dependencies
node_modules/
package-lock.json

# Release artifacts
.scrub.log

# Local settings (root level only)
/settings.local.json

# Allow config/settings.json (the source of truth)
!config/settings.json

# Logs and temp files
*.log
.DS_Store

# Sensitive data
*secret*
*_token*
*-token*
*.token
*key*
!skills/**/keyword*
.env

# Session-specific files (don't share across computers)
debug/
file-history/
history.jsonl
shell-snapshots/
todos/
projects/
.update_check

# Cost tracking (personal usage data)
.claude/cost-tracking.json
cost-tracking.json

# Backups
*.backup
BACKLOG.md.ralph-next-backup

# Claude Code worktrees (transient parallel-agent artifacts)
.claude/worktrees/

# Session artifacts (transient — not shared across machines)
.playwright-mcp/
.claude/ralph-next/quality-*.json
.claude/ralph-next/evidence/

